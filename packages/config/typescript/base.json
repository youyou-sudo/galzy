{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "incremental": false,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "paths": {
      "@web/*": ["../../../apps/web/src/*"],
      "@web/public/*": ["../../../apps/web/public/*"],
      "@web/components": ["../../../apps/web/src/components/index.ts"],
      "@web/layouts": ["../../../apps/web/src/layouts/index.ts"],
      "@web/stores": ["../../../apps/web/src/stores/index.ts"],
      "@web/libs": ["../../../apps/web/src/libs/index.ts"],
      "@api": ["../../../apps/api/src/index.ts"],
      "@api/*": ["../../../packages/apps/api/src/*"],
      "@libs": ["../../../packages/libs/src/index.ts"],
      "@libs/*": ["../../../packages/libs/src/*"]
    }
  },
  "exclude": ["coverage", ".storybook", "node_modules"]
}
