{
  "extends": "config/typescript/base.json",
  "include": [
    "src",
    "test",
    "scripts",
    "eslint.config.js",
    "postcss.config.mjs"
  ],
  "compilerOptions": {
    "paths": {
      "@web/*": ["../../apps/web/src/*"],
      "@api": ["../../apps/api/src/index.ts"],
      "@api/*": ["../../apps/api/src/*"],
      "@libs": ["../../packages/libs/src/index.ts"],
      "@libs/*": ["../../packages/libs/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "coverage", ".storybook"]
}
