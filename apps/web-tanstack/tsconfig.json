{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "env.d.ts",
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "#/*": [
        "./src/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "@api": [
        "../api/src/index.ts"
      ],
      "@api/*": [
        "../api/src/*"
      ],
      "@libs": [
        "../../packages/libs/src/index.ts"
      ],
      "@libs/*": [
        "../../packages/libs/src/*"
      ]
    },
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client"
    ],
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
