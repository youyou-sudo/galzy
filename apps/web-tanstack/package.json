{
  "name": "web-tanstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bunx --bun vite dev --port 3000",
    "build": "bunx --bun vite build",
    "preview": "bun --bun vite preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "format": "biome format --write .",
    "check": "biome check",
    "docker": "cd ../.. && docker build -t mono-web:$(node -e \"console.log(require('./apps/api/package.json').version)\") -f ./apps/web-tanstack/Dockerfile .",
    "docker:web-tanstack": "cd ../.. && docker build -t mono-web:$(node -e \"console.log(require('./apps/api/package.json').version)\") -f ./apps/web-tanstack/Dockerfile ."
  },
  "dependencies": {
    "@bprogress/core": "^1.3.4",
