{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server ./src/index.ts",
    "lint": "biome check --write",
    "format": "biome format --write .",
    "check": "biome check",
    "docker": "cd ../.. && docker build -t mono-api:$(node -e \"console.log(require('./apps/api/package.json').version)\") -f ./apps/api/Dockerfile .",
    "docker:api": "cd ../.. && docker build -t mono-api:$(node -e \"console.log(require('./apps/api/package.json').version)\") -f ./apps/api/Dockerfile ."
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/opentelemetry": "1.4.11",
    "@elysiajs/swagger": "^1.3.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/xxhashjs": "^0.2.4",
    "ajv": "^8.20.0",
    "croner": "^10.0.1",
    "elysia": "^1.4.28",
    "kysely": "^0.29.0",
    "kysely-bun-sql": "^0.2.0",
    "kysely-postgres-js": "^3.0.0",
    "meilisearch": "^0.58.0",
    "xxhashjs": "^0.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "config": "workspace:*"
  }
}
