{
  "extends": "config/typescript/base.json",
  "compilerOptions": {
    "jsx": "react",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "paths": {
      "@web/*": ["../web/src/*"],
      "@api": ["./src/index.ts"],
      "@api/*": ["./src/*"],
      "@libs": ["../../packages/libs/src/index.ts"],
      "@libs/*": ["../../packages/libs/src/*"]
    }
  },
  "include": ["src", "test", "scripts", "eslint.config.mjs"],
  "exclude": ["dist"]
}
