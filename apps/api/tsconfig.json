{
  "extends": "config/typescript/base.json",
  "compilerOptions": {
    "jsx": "react",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "paths": {
      "@web/*": [
        "apps/web/src/*"
      ],
      "@api/*": [
        "apps/api/src/*"
      ],
      "@libs": [
        "packages/libs/src/index.ts"
      ],
      "@libs/*": [
        "packages/libs/src/*"
      ],
      "@ui": [
        "packages/ui/src/index.ts"
      ],
      "@ui/*": [
        "packages/ui/src/*"
      ]
    }
  },
  "include": [
    "src",
    "test",
    "scripts",
    "eslint.config.mjs"
  ],
  "exclude": [
    "dist"
  ]
}
